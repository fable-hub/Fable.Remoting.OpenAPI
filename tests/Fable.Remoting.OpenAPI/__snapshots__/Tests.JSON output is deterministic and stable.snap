                "type": "string"
              }
            },
            "required": [
              "case",
              "reason"
            ],
            "type": "object"
          }
        ]
      },
      "SearchRequest": {
        "properties": {
          "IncludeArchived": {
            "nullable": true,
            "type": "boolean"
          },
