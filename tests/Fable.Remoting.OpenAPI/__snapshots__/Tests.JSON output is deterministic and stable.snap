              "nullable": true,
              "type": "string"
            },
            "properties": {},
            "type": "object"
          },
          "Query": {
            "type": "string"
          },
          "Tags": {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "required": [
          "Query",
          "Tags",
          "Metadata"
        ],
        "type": "object"
      },
      "SearchResponse": {
        "properties": {
          "Items": {
            "items": {
              "$ref": "#/components/schemas/Customer"
            },
            "type": "array"
          },
          "Total": {
            "type": "integer"
          }
        },
        "required": [
          "Total",
          "Items"
        ],
        "type": "object"
      }
    }
